-- Auto-generates src/signatures.rs from typedef files.
-- Run with: seal src/scripts/signature_generation/generate.luau

local discovery = require("./discovery")
local fs = require("@std/fs")
local colors = require("@std/io/colors")

local OUTPUT_PATH = discovery.REPO_ROOT .. "/src/signatures.rs"

-- ── Constant name derivation ──────────────────────────────────────────────────

local function to_screaming(s: string): string
    s = string.gsub(s, "(%l)(%u)", "%1_%2")
    return string.upper(s)
end

local function make_const_name(prefix: string, fn_name: string): string
    local parts = {}
    for part in string.gmatch(prefix, "[^%.]+") do
        table.insert(parts, to_screaming(part))
    end
    table.insert(parts, to_screaming(fn_name))
    return "STD_" .. table.concat(parts, "_")
end

-- ── Generate ──────────────────────────────────────────────────────────────────

local lines = {
    "// Auto-generated by `seal src/scripts/signature_generation/generate.luau`",
    "// Do not edit manually — run the generator to regenerate.",
    "//",
    "// These constants expose typedef-derived function signatures so that",
    "// `TableBuilder::with_function_and_signature` calls stay in sync with typedefs.",
    "",
    "#![allow(dead_code)]",
    "",
}

local total = 0
local entries = discovery.discover_entries()
local last_prefix = ""

for _, entry in entries do
    local module_var_hint = string.match(entry.prefix, "[^%.]+$") or entry.prefix
    local sep = if entry.is_method then ":" else "."
    local fns = discovery.extract_fn_sigs(entry.file_path, entry.is_method, entry.type_name, module_var_hint, entry.prop_path)

    local fn_names: { string } = {}
    for name in fns do
        if fns[name] ~= "<complex>" then
            table.insert(fn_names, name)
        end
    end
    table.sort(fn_names)

    if #fn_names == 0 then continue end

    if entry.prefix ~= last_prefix then
        table.insert(lines, `// {entry.prefix}`)
        last_prefix = entry.prefix
    end

    for _, fn_name in fn_names do
        local type_sig = fns[fn_name]
        local const_name = make_const_name(entry.naming_prefix, fn_name)
        local full_sig = string.gsub(entry.prefix .. sep .. fn_name .. type_sig, '"', '\\"')
        table.insert(lines, `pub const {const_name}: &std::ffi::CStr = c"{full_sig}";`)
        total += 1
    end

    table.insert(lines, "")
end

fs.writefile(OUTPUT_PATH, table.concat(lines, "\n"))
print(colors.bold.green("✓") .. ` wrote {total} constants to {colors.style.dim(OUTPUT_PATH)}`)
